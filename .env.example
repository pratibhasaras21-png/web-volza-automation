# Gmail IMAP credentials
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email address to enter on the Volza sign-in page (usually same as GMAIL_USER)
VOLZA_LOGIN_EMAIL=your-email@gmail.com

# OTP email filter settings
OTP_SENDER_DOMAIN=volza.com
OTP_SUBJECT_KEYWORD=OTP
OTP_WAIT_MS=60000
OTP_POLL_INTERVAL_MS=5000
